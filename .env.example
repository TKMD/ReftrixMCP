# Reftrix Environment Variables
# Copy this file to .env.local and fill in your values

# Database (PostgreSQL + pgvector)
# Port offset: 21000 (standard: 5432 -> 26432)
DATABASE_URL="postgresql://reftrix:change_me@localhost:26432/reftrix?schema=public"

# Redis (for BullMQ async job processing)
# Port offset: 21000 (standard: 6379 -> 27379)
REDIS_URL="redis://localhost:27379"
REDIS_HOST=localhost
REDIS_PORT=27379

# Application
NODE_ENV="development"

# Internal API URL (not used in MCP-only mode)
REFTRIX_API_URL="http://localhost:24000/api/v1"

# Embedding Model
MODEL_CACHE_DIR="./.cache/models"
EMBEDDING_BATCH_SIZE=32

# ONNX Execution Provider: cpu (default) | cuda (NVIDIA GPU)
# CUDA requires the CUDA provider to be downloaded:
#   ONNXRUNTIME_NODE_INSTALL_CUDA=v12 node node_modules/onnxruntime-node/script/install.js
# And LD_LIBRARY_PATH set to include CUDA runtime libraries (see docs)
# ONNX_EXECUTION_PROVIDER=cpu

# Security
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-change-in-production"  # Phase 2: Not yet implemented

# === Ollama Vision (optional, for NARRATIVE phase) ===
# Requires Ollama installed: https://ollama.com
OLLAMA_BASE_URL="http://localhost:11434"

# === MCP Authentication (recommended for production) ===
MCP_AUTH_ENABLED="false"
# JSON array of API key objects (required when MCP_AUTH_ENABLED=true)
# Each object: { key, role (VIEWER|USER|ADMIN), userId, expiresAt? (ISO 8601) }
# MCP_API_KEYS='[{"key":"reftrix_your_key_here","role":"ADMIN","userId":"admin-001"},{"key":"reftrix_another_key","role":"USER","userId":"user-001","expiresAt":"2027-01-01T00:00:00Z"}]'

# === Worker Configuration (optional tuning) ===
WORKER_MAX_JOBS_BEFORE_RESTART=1
# WORKER_CONCURRENCY=1
# WORKER_MAX_RESTART_ATTEMPTS=10
# WORKER_SHUTDOWN_TIMEOUT_MS=10000

# === Crawling: robots.txt Compliance ===
# When true (default), respects robots.txt Disallow directives before crawling.
# Set to "false" to disable. See PRIVACY_POLICY.md Section 4.3.
REFTRIX_RESPECT_ROBOTS_TXT="true"

# === ML/Embedding ===
# MODEL_CACHE_DIR is set above
# ONNX_EXECUTION_PROVIDER="cpu"  # Options: cpu, cuda, rocm
