// ============================================================================
// WebGL Animation Pattern Models
// Shader-based WebGL/Canvas animations detected via visual frame analysis
// Supports WebGL 1.0/2.0, Three.js, Custom shaders
// ============================================================================

/// WebGLアニメーションのカテゴリ分類
enum WebGLAnimationCategory {
  fade // フェードイン/アウト
  pulse // 脈動・点滅
  wave // 波状アニメーション
  particle // パーティクルシステム
  morph // 形状変形
  rotation // 回転アニメーション
  parallax // パララックス効果
  noise // ノイズベースアニメーション（Perlin等）
  complex // 複合・分類不能
}

/// WebGLAnimationPattern - WebGL/Canvas シェーダーアニメーションパターン
/// フレーム差分解析によるビジュアル検出結果を保存
/// Three.js, Custom Shader, WebGL 1.0/2.0 の検出結果を統合管理
model WebGLAnimationPattern {
  id        String  @id @default(dbgenerated("gen_uuidv7()")) @db.Uuid
  webPageId String? @map("web_page_id") @db.Uuid

  // パターン基本情報
  name        String                 @db.VarChar(200)
  category    WebGLAnimationCategory
  description String?                @db.Text

  // Canvas要素情報
  canvasSelector String? @map("canvas_selector") @db.VarChar(500) // CSSセレクタ
  canvasWidth    Int?    @map("canvas_width") // Canvas幅（ピクセル）
  canvasHeight   Int?    @map("canvas_height") // Canvas高さ（ピクセル）
  webglVersion   Int?    @map("webgl_version") // 1 = WebGL 1.0, 2 = WebGL 2.0

  // 検出ライブラリ情報
  detectedLibraries String[] @default([]) @map("detected_libraries") // "three.js", "pixi.js", "custom"等

  // フレーム解析結果
  frameAnalysis Json @map("frame_analysis")
  /**
   * {
   * "totalFrames": 120,
   * "analyzedFrames": 60,
   * "fps": 30,
   * "duration_ms": 4000,
   * "avgDiffPercentage": 0.15,
   * "maxDiffPercentage": 0.45,
   * "animationIntensity": 0.65
   * }
   */

  // 変化領域（BoundingBox[]）
  changeRegions Json @default("[]") @map("change_regions")
  /**
   * [
   * { "x": 100, "y": 50, "width": 400, "height": 300, "changeRatio": 0.85 },
   * { "x": 500, "y": 200, "width": 200, "height": 150, "changeRatio": 0.42 }
   * ]
   */

  // 視覚特徴
  visualFeatures Json @default("{}") @map("visual_features")
  /**
   * {
   * "dominantColors": ["#1a1a2e", "#16213e", "#0f3460"],
   * "motionDirection": "radial" | "horizontal" | "vertical" | "random",
   * "periodicPattern": true,
   * "estimatedPeriodMs": 2000,
   * "hasParticles": true,
   * "hasGradients": true,
   * "usesBlending": true
   * }
   */

  // パフォーマンス情報
  performance Json @default("{}")
  /**
   * {
   * "estimatedFps": 60,
   * "gpuIntensive": true,
   * "memoryUsage": "high",
   * "drawCalls": 150,
   * "triangleCount": 10000
   * }
   */

  // アクセシビリティ
  accessibility Json @default("{}")
  /**
   * {
   * "respectsReducedMotion": false,
   * "hasStaticFallback": false,
   * "seizureRisk": "low" | "medium" | "high"
   * }
   */

  // 検出信頼度（0-1）
  confidence Float?

  // ソース情報
  sourceUrl  String? @map("source_url") @db.Text
  usageScope String  @default("inspiration_only") @map("usage_scope")

  // メタデータ
  tags     String[] @default([])
  metadata Json     @default("{}")

  // タイムスタンプ
  detectedAt DateTime @default(now()) @map("detected_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage   WebPage?                 @relation(fields: [webPageId], references: [id], onDelete: SetNull)
  embedding WebGLAnimationEmbedding?

  @@index([webPageId])
  @@index([category])
  @@index([detectedAt(sort: Desc)])
  @@map("webgl_animation_patterns")
}

