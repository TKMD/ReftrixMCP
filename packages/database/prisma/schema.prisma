/// MotionAnalysisResult - フレーム画像解析結果
/// resultType: 'animation_zone' | 'layout_shift' | 'motion_vector'
/// AnimationZone, LayoutShift, MotionVector の3種類の解析結果を統合保存
model MotionAnalysisResult {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webPageId String? @map("web_page_id") @db.Uuid

  // 解析結果タイプ
  resultType String @map("result_type") // 'animation_zone' | 'layout_shift' | 'motion_vector'

  // フレーム情報
  frameIndex Int @map("frame_index") // 対象フレームインデックス
  fps        Int @default(30) // フレームレート

  // === AnimationZone (resultType = 'animation_zone') ===
  // 差分分析結果: 変化したピクセル数、変化率、変化領域
  /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /*
   * {
   * "changedPixels": 12500,
   * "totalPixels": 2073600,
   * "changeRatio": 0.006,
   * "hasChange": true,
   * "regions": [{ "x": 100, "y": 200, "width": 300, "height": 150 }]
   * }
   */

  // === LayoutShift (resultType = 'layout_shift') ===
  // CLS影響スコア、影響領域、推定原因
  /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /*
   * {
   * "shiftStartMs": 500,
   * "impactScore": 0.15,
   * "affectedRegions": [{ "x": 0, "y": 100, "width": 1920, "height": 200 }],
   * "estimatedCause": "image_load",
   * "shiftDirection": 90,
   * "shiftDistance": 50
   * }
   */

  // === MotionVector (resultType = 'motion_vector') ===
  // 方向、速度、モーションタイプ
  /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /*
   * {
   * "dominantDirection": 270,
   * "avgSpeed": 15.5,
   * "maxSpeed": 30.2,
   * "confidence": 0.85,
   * "motionType": "slide_left"
   * }
   */

  // 解析結果データ（上記3タイプに共通のJSON構造）
  resultData Json @map("result_data")

  // 影響領域（BoundingBox[]のJSON）
  // AnimationZone.regions, LayoutShift.affectedRegions を格納
  affectedRegions Json @default("[]") @map("affected_regions")

  // メタデータ
  metadata Json @default("{}")

  // ソース情報
  sourceUrl  String? @map("source_url") @db.Text
  usageScope String  @default("inspiration_only") @map("usage_scope")

  // タイムスタンプ
  analyzedAt DateTime @default(now()) @map("analyzed_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage   WebPage?                 @relation(fields: [webPageId], references: [id], onDelete: SetNull)
  embedding MotionAnalysisEmbedding?

  @@index([webPageId])
  @@index([resultType])
  @@index([frameIndex])
  @@index([webPageId, resultType])
  @@index([analyzedAt(sort: Desc)])
  @@map("motion_analysis_results")
}

/// MotionAnalysisEmbedding - フレーム画像解析結果のベクトル埋め込み
/// セマンティック検索用（例: "フェードインアニメーション" "CLS問題のあるレイアウト"）
