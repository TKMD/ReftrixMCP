// Reftrix Database Schema
// PostgreSQL 18 + pgvector 0.8
// WebDesign Analysis Platform (MCP-only, no WebUI)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector, pg_trgm, pgcrypto]
}

