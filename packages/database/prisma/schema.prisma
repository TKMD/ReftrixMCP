  // 評価メタデータ
  evaluatorVersion String @map("evaluator_version")
  evaluationMode   String @default("standard") @map("evaluation_mode") // 'standard' | 'strict'

  // 評価時に参照したパターン
  referencedPatterns Json? @map("referenced_patterns")
  /**
   * {
   * "similar_sections": ["uuid1", "uuid2", "uuid3"],
