/// Vision AIやCSS解析から判定されるデザインの雰囲気・印象
enum MoodCategory {
  professional // プロフェッショナル・ビジネス向け
  playful // 遊び心のある・カジュアル
  premium // 高級感・ラグジュアリー
  tech // テクノロジー・先進的
  organic // 自然・オーガニック
  minimalist // ミニマル・シンプル
  bold // 大胆・インパクト
  elegant // エレガント・上品
  artistic // アーティスティック・創造的
  trustworthy // 信頼感・安心感
  innovative // 革新的・先駆的
  warm // 温かみのある・親しみやすい
  mysterious // 神秘的・ミステリアス
  energetic // 活発・エネルギッシュ
  serene // 静謐・穏やか
  other // その他
}

/// DesignNarrative - デザインの物語性・世界観を構造化データとして管理
/// Vision AI分析結果から抽出したムード、トーン、視覚的特徴を保存
/// 1 WebPage : 1 DesignNarrative（1対1関係）
model DesignNarrative {
  id        String @id @default(dbgenerated("gen_uuidv7()")) @db.Uuid
  webPageId String @unique @map("web_page_id") @db.Uuid

  // ムード分類（主要な雰囲気・印象）
  moodCategory    MoodCategory @map("mood_category")
  moodDescription String?      @map("mood_description") @db.Text

  // 色彩印象（Vision AIからの色彩分析結果）
  // 例: "暖色系の落ち着いた色調で信頼感を演出"
  colorImpression String? @map("color_impression") @db.Text

  // タイポグラフィの性格
  // 例: "モダンなサンセリフで親しみやすさを表現"
  typographyPersonality String? @map("typography_personality") @db.Text

  // モーションの感情表現
  // 例: "滑らかな遷移で洗練された印象を与える"
  motionEmotion String? @map("motion_emotion") @db.Text

  // 全体的なトーン・雰囲気
  // 例: "プロフェッショナルでありながら親しみやすい"
  overallTone String? @map("overall_tone") @db.Text

  // レイアウト構造（JSONB）
  // { "type": "asymmetric", "grid": "12-column", "whitespace": "generous" }
  layoutStructure Json @default("{}") @map("layout_structure")

  // 視覚的階層（JSONB）
  // { "levels": 4, "primaryFocus": "hero", "secondaryFocus": "features" }
  visualHierarchy Json @default("{}") @map("visual_hierarchy")

  // 余白のリズム（JSONB）
  // { "pattern": "consistent", "baseUnit": 8, "scale": [4, 8, 16, 32, 64] }
  spacingRhythm Json @default("{}") @map("spacing_rhythm")

  // セクション間の関係性（JSONB）
  // { "flow": "narrative", "connections": ["hero->features", "features->cta"] }
  sectionRelationships Json @default("{}") @map("section_relationships")

  // グラフィック要素（JSONB）
  // { "illustrations": true, "icons": "outline", "patterns": "geometric" }
  graphicElements Json @default("{}") @map("graphic_elements")

  // ソースURL（重複保持、検索効率のため）
  sourceUrl String? @map("source_url") @db.Text

  // 分析信頼度（0-1）
  confidence Float? @default(0.0)

  // 分析日時
  analyzedAt DateTime @default(now()) @map("analyzed_at") @db.Timestamptz

  // 分析アルゴリズムバージョン
  analyzerVersion String @default("0.1.0") @map("analyzer_version") @db.VarChar(50)

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage   WebPage                   @relation(fields: [webPageId], references: [id], onDelete: Cascade)
  embedding DesignNarrativeEmbedding?

  @@index([webPageId])
  @@index([moodCategory])
  @@index([analyzedAt(sort: Desc)])
  @@index([confidence(sort: Desc)])
  @@map("design_narratives")
}

/// DesignNarrativeEmbedding - デザインナラティブのベクトル埋め込み
/// セマンティック検索用（例: "温かみのあるプロフェッショナルなデザイン"）
/// HNSW Index: idx_design_narrative_embeddings_hnsw (m=16, ef_construction=64, vector_cosine_ops)
/// Performance Target: Vector Search P95 < 100ms
model DesignNarrativeEmbedding {
  id                String @id @default(dbgenerated("gen_uuidv7()")) @db.Uuid
  designNarrativeId String @unique @map("design_narrative_id") @db.Uuid

  // Embedding (768D, multilingual-e5-base)
  // HNSW indexed for semantic search
  embedding Unsupported("vector(768)")? @map("embedding")

  // テキスト表現（Embedding生成元）
  // 例: "professional mood with warm color palette, modern typography, smooth transitions"
  textRepresentation String? @map("text_representation") @db.Text

  // 全文検索用tsvectorカラム（GENERATED ALWAYS AS）
  // PostgreSQL側でtext_representationから自動生成、GINインデックス付き
  searchVector Unsupported("tsvector")? @map("search_vector")

  // メタデータ
  modelVersion       String   @map("model_version") // 'multilingual-e5-base'
  embeddingTimestamp DateTime @default(now()) @map("embedding_timestamp") @db.Timestamptz

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  designNarrative DesignNarrative @relation(fields: [designNarrativeId], references: [id], onDelete: Cascade)

  @@map("design_narrative_embeddings")
}

// ============================================================================
// Background Design Models
// Reference: 背景デザインパターンの検出・分類・セマンティック検索
// solid_color, gradient, glassmorphism, noise_texture, SVG pattern 等を管理
// ============================================================================

/// 背景デザインタイプ分類（14種類）
/// CSS静的解析およびVision AI解析から判定される背景デザインの種類
enum BackgroundDesignType {
  solid_color // 単色背景
  linear_gradient // 線形グラデーション
  radial_gradient // 放射状グラデーション
  conic_gradient // 円錐グラデーション
  mesh_gradient // メッシュグラデーション
  image_background // 画像背景
  pattern_background // パターン背景（繰り返し画像）
  video_background // 動画背景
  animated_gradient // アニメーショングラデーション
  glassmorphism // ガラスモーフィズム（blur + transparency）
  noise_texture // ノイズテクスチャ
  svg_background // SVGパターン背景
  multi_layer // 複合レイヤー（複数背景の組み合わせ）
  unknown // 分類不能
}

/// BackgroundDesign - 背景デザインパターン
/// Webページから検出された背景デザインの分類・色彩情報・グラデーション情報等を保存
/// SectionPatternとの関連により、特定セクションの背景情報を紐付け可能
model BackgroundDesign {
  id               String  @id @default(dbgenerated("gen_uuidv7()")) @db.Uuid
  webPageId        String? @map("web_page_id") @db.Uuid
  sectionPatternId String? @map("section_pattern_id") @db.Uuid

  // 基本情報
  name          String              @db.VarChar(200)
  designType    BackgroundDesignType @map("design_type")
  cssValue      String              @map("css_value") @db.Text
  selector      String?             @db.VarChar(500)
  positionIndex Int                 @default(0) @map("position_index")

  // 色彩情報（JSONB）
  // { "dominantColors": ["#1a1a2e", "#16213e"], "colorCount": 3, "hasAlpha": true, "colorSpace": "srgb" }
  colorInfo Json @default("{}") @map("color_info")

  // グラデーション情報（JSONB, nullable）
  // { "type": "linear", "angle": 135, "stops": [{"color":"#1a1a2e","position":0}], "repeating": false }
  gradientInfo Json? @map("gradient_info")

  // 視覚プロパティ（JSONB）
  // { "blurRadius": 0, "opacity": 1.0, "blendMode": "normal", "hasOverlay": false, "layers": 1 }
  visualProperties Json @default("{}") @map("visual_properties")

  // アニメーション情報（JSONB, nullable）
  // { "isAnimated": true, "animationName": "gradient-shift", "duration": "3s", "easing": "ease-in-out" }
  animationInfo Json? @map("animation_info")

  // CSS実装コード
  cssImplementation String? @map("css_implementation") @db.Text

  // パフォーマンス情報（JSONB）
  // { "gpuAccelerated": true, "triggersPaint": true, "estimatedImpact": "low" }
  performance Json @default("{}") @map("performance")

  // メタデータ
  tags     String[] @default([])
  metadata Json     @default("{}")

  // 検出信頼度（0-1）
  confidence Float?

  // ソース情報
  sourceUrl  String? @map("source_url") @db.Text
  usageScope String  @default("inspiration_only") @map("usage_scope")

  // タイムスタンプ
  detectedAt DateTime @default(now()) @map("detected_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage        WebPage?                   @relation(fields: [webPageId], references: [id], onDelete: SetNull)
  sectionPattern SectionPattern?            @relation(fields: [sectionPatternId], references: [id], onDelete: SetNull)
  embedding      BackgroundDesignEmbedding?

  @@index([webPageId])
  @@index([designType])
  @@index([sectionPatternId])
  @@index([detectedAt(sort: Desc)])
  @@map("background_designs")
}

/// BackgroundDesignEmbedding - 背景デザインパターンのベクトル埋め込み
/// セマンティック検索用（例: "ダークなグラデーション背景" "ガラスモーフィズム効果"）
/// HNSW Index: idx_background_design_embeddings_hnsw (m=16, ef_construction=64, vector_cosine_ops)
/// Performance Target: Vector Search P95 < 100ms
model BackgroundDesignEmbedding {
  id                 String @id @default(dbgenerated("gen_uuidv7()")) @db.Uuid
  backgroundDesignId String @unique @map("background_design_id") @db.Uuid

  // Embedding (768D, multilingual-e5-base)
  // HNSW indexed for semantic search
  embedding Unsupported("vector(768)")? @map("embedding")

  // テキスト表現（Embedding生成元）
  // 例: "dark linear gradient background with glassmorphism overlay, animated color shift"
  textRepresentation String? @map("text_representation") @db.Text

  // 全文検索用tsvectorカラム（GENERATED ALWAYS AS）
  // PostgreSQL側でtext_representationから自動生成、GINインデックス付き
  searchVector Unsupported("tsvector")? @map("search_vector")

  // メタデータ
  modelVersion       String   @map("model_version") // 'multilingual-e5-base'
  embeddingTimestamp DateTime @default(now()) @map("embedding_timestamp") @db.Timestamptz

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  backgroundDesign BackgroundDesign @relation(fields: [backgroundDesignId], references: [id], onDelete: Cascade)

  @@map("background_design_embeddings")
}
