// ============================================================================
// MCP Creative Tools - Brand Palette Models
// Reference: MCP Creative Tools Phase 1 (style.get_palette, style.apply)
// ============================================================================

/// パレットモード（ライト/ダーク/システム）
enum PaletteMode {
  light
  dark
  system
}

/// カラートークンのロール（役割）
enum ColorRole {
  primary
  secondary
  accent
  neutral
  semantic
}

/// ブランドパレット - ブランドカラーセットを管理
/// MCPツール: style.get_palette, style.apply で使用
model BrandPalette {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @db.VarChar(200)
  slug        String      @unique @db.VarChar(100)
  description String?     @db.Text
  mode        PaletteMode @default(light)
  isDefault   Boolean     @default(false) @map("is_default")

  // Relations
  tokens         ColorToken[]

  // WebDesign WebUI Relations
  projectBrandSettings ProjectBrandSetting[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([mode])
  @@index([isDefault])
  @@map("brand_palettes")
}

/// カラートークン - パレット内の個別カラー定義
/// OKLCHカラースペースでの色値を保持（モダンCSS対応）
model ColorToken {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paletteId       String    @map("palette_id") @db.Uuid
  name            String    @db.VarChar(100)
  hex             String    @db.VarChar(7) // #RRGGBB format
  oklchL          Float     @map("oklch_l") // Lightness: 0-1
  oklchC          Float     @map("oklch_c") // Chroma: 0-0.4
  oklchH          Float     @map("oklch_h") // Hue: 0-360
  role            ColorRole
  semanticMeaning String?   @map("semantic_meaning") @db.VarChar(200)
  sortOrder       Int       @default(0) @map("sort_order")

  // Relations
  palette BrandPalette @relation(fields: [paletteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([paletteId, name])
  @@index([paletteId])
  @@index([role])
  @@map("color_tokens")
}

// ============================================================================
// Webdesign Analysis Models
// Reference: docs/plans/webdesign/07-database-schema.md
// ============================================================================

/// 段階的分析ステータス（Phase2-2: 部分結果即時DB保存）
/// 各フェーズ完了時にステータスを更新し、タイムアウト時も部分結果を保持
enum AnalysisPhaseStatus {
  pending // 未開始
  layout_done // Layoutフェーズ完了
  motion_done // Layout + Motionフェーズ完了
  quality_done // 全フェーズ完了（completedと同義）
  completed // 完全完了（quality_doneのエイリアス）
  failed // 失敗（エラー発生）
}

/// WebPage - 解析対象のWebページ基本情報
/// sourceType: 'award_gallery' | 'user_provided'
/// usageScope: 'inspiration_only' | 'owned_asset' | 'commercial_reuse_allowed'
/// analysisStatus: 'pending' | 'processing' | 'completed' | 'failed'（後方互換性維持）
/// analysisPhaseStatus: AnalysisPhaseStatus（段階的分析用）
model WebPage {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String? @map("project_id") @db.Uuid // Optional: WebPages created before this migration
  url         String  @unique
  title       String?
  description String? @db.Text

  // ソース情報
  sourceType     String  @map("source_type") // 'award_gallery' | 'user_provided'
  sourcePlatform String? @map("source_platform") // 'cssda' | 'fwa' | 'awwwards' | 'custom'
  awardInfo      Json?   @map("award_info")

  // 利用範囲
  usageScope  String  @map("usage_scope") // 'inspiration_only' | 'owned_asset' | 'commercial_reuse_allowed'
  licenseNote String? @map("license_note") @db.Text

  // コンテンツ
  htmlContent String? @map("html_content") @db.Text // 圧縮HTML
  htmlHash    String? @map("html_hash") @db.VarChar(64) // 変更検知用ハッシュ

  // スクリーンショット
  screenshotDesktopUrl String? @map("screenshot_desktop_url") @db.Text
  screenshotMobileUrl  String? @map("screenshot_mobile_url") @db.Text
  screenshotFullUrl    String? @map("screenshot_full_url") @db.Text

  // 解析ステータス（後方互換性維持）
  analysisStatus  String    @default("pending") @map("analysis_status") // 'pending' | 'processing' | 'completed' | 'failed'
  analyzedAt      DateTime? @map("analyzed_at") @db.Timestamptz
  analysisVersion String?   @map("analysis_version") // 解析アルゴリズムバージョン

  // 段階的分析ステータス（Phase2-2: 部分結果即時DB保存）
  // 各フェーズ完了時にステータスを更新し、タイムアウト時も部分結果を保持
  analysisPhaseStatus AnalysisPhaseStatus @default(pending) @map("analysis_phase_status")
  lastAnalyzedPhase   String?             @map("last_analyzed_phase") // 最後に完了したフェーズ: 'layout' | 'motion' | 'quality'
  analysisError       String?             @map("analysis_error") @db.Text // エラーメッセージ
  analysisStartedAt   DateTime?           @map("analysis_started_at") @db.Timestamptz // 分析開始時刻
  analysisCompletedAt DateTime?           @map("analysis_completed_at") @db.Timestamptz // 分析完了時刻

  // メタデータ
  metadata Json @default("{}")

  // Pre-flight Probe結果（ページ複雑度メトリクス）
  // layout.ingest/page.analyze実行前の軽量プローブで取得
  // タイムアウト値の動的計算に使用
  complexityMetrics Json? @map("complexity_metrics")
  /**
   * {
   *   "responseTimeMs": number,         // HEAD/初期レスポンス時間
   *   "htmlSizeBytes": number,          // HTMLサイズ
   *   "scriptCount": number,            // <script>タグ数
   *   "externalResourceCount": number,  // 外部リソース数
   *   "hasWebGL": boolean,              // WebGL使用検出
   *   "hasSPA": boolean,                // SPA検出（React/Vue/Angular等）
   *   "hasHeavyFramework": boolean,     // Three.js等の重いフレームワーク
   *   "calculatedTimeoutMs": number,    // 計算されたタイムアウト値
   *   "complexityScore": number,        // 複雑度スコア (0-100)
   *   "probedAt": string,               // ISO 8601
   *   "probeVersion": string            // "0.1.0"
   * }
   */

  // タイムスタンプ
  crawledAt DateTime @default(now()) @map("crawled_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  project                Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sectionPatterns        SectionPattern[]
  motionPatterns         MotionPattern[]
  jsAnimationPatterns    JSAnimationPattern[]
  webglAnimationPatterns WebGLAnimationPattern[]
  motionAnalysisResults  MotionAnalysisResult[]
  qualityBenchmarks      QualityBenchmark[]
  designNarrative        DesignNarrative? // 1:1 relationship
  backgroundDesigns      BackgroundDesign[]

  @@index([projectId])
  @@index([projectId, analysisStatus])
  @@index([sourceType])
  @@index([sourcePlatform])
  @@index([analysisStatus])
  @@index([analysisPhaseStatus])
  @@index([projectId, analysisPhaseStatus])
  @@index([crawledAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("web_pages")
}

/// SectionPattern - セクションパターン（ヒーロー、フィーチャー、CTA等）
/// sectionType: 'hero' | 'features' | 'cta' | 'testimonial' | 'pricing' | 'footer' | etc.
model SectionPattern {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webPageId     String  @map("web_page_id") @db.Uuid
  sectionType   String  @map("section_type")
  sectionName   String? @map("section_name")
  positionIndex Int     @map("position_index") // ページ内の順序

  // レイアウト情報（JSON構造体）
  layoutInfo Json @map("layout_info")
  /**
   * {
   * "type": "hero",
   * "grid": { "columns": 2, "gap": "32px" },
   * "alignment": "left",
   * "content_blocks": [...],
   * "responsive": {...}
   * }
   */

  // コンポーネント情報
  components Json @default("[]")
  /**
   * [
   * { "type": "heading", "level": 1, "text": "..." },
   * { "type": "button", "variant": "primary", "text": "..." }
   * ]
   */

  // 視覚特徴
  visualFeatures Json @default("{}") @map("visual_features")
  /**
   * {
   * "color_scheme": { "dominant": "#...", "accent": "#..." },
   * "density": 0.65,
   * "whitespace_ratio": 0.35,
   * "image_ratio": 0.4
   * }
   */

  // HTML/CSS（参照用）
  htmlSnippet String? @map("html_snippet") @db.Text
  cssSnippet  String? @map("css_snippet") @db.Text

  // 外部CSSコンテンツ（motion.detect/layout.ingestで取得した外部CSSファイルの実コンテンツ）
  // cssSnippetはページ内CSS（インライン、<style>タグ、@import参照）を保持
  // externalCssContentは外部ファイル（<link rel="stylesheet">）の実際の内容を保持
  externalCssContent String? @map("external_css_content") @db.Text
  externalCssMeta    Json?   @map("external_css_meta")
  /**
   * {
   * "fetchedCount": 3,
   * "failedCount": 1,
   * "totalSize": 245678,
   * "urls": [
   * { "url": "https://cdn.example.com/styles.css", "size": 120000, "success": true },
   * { "url": "https://cdn.example.com/theme.css", "size": 125678, "success": true }
   * ],
   * "fetchedAt": "2026-01-05T10:30:00Z"
   * }
   */

  // CSSフレームワーク検出結果
  // 値: tailwind, bootstrap, css_modules, styled_components, vanilla, unknown
  cssFramework     String? @map("css_framework") @db.VarChar(50)
  cssFrameworkMeta Json?   @default("{}") @map("css_framework_meta")
  /**
   * {
   * "confidence": 0.95,
   * "evidence": ["Tailwind CDN detected", "utility classes found: flex, items-center"]
   * }
   */

  // 品質スコア
  qualityScore Json? @map("quality_score")
  /**
   * {
   * "anti_ai_cliche": { "overall": 85, "axes": {...} },
   * "visual_hierarchy": 90,
   * "accessibility": 82
   * }
   */

  // メタデータ
  tags     String[] @default([])
  metadata Json     @default("{}")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage            WebPage            @relation(fields: [webPageId], references: [id], onDelete: Cascade)
  embedding          SectionEmbedding?
  qualityBenchmarks  QualityBenchmark[]
  backgroundDesigns  BackgroundDesign[]

  @@index([webPageId])
  @@index([sectionType])
  @@index([cssFramework])
  @@index([webPageId, positionIndex])
  @@map("section_patterns")
}

/// SectionEmbedding - セクションパターンのベクトル埋め込み
/// HNSW Indexes (m=16, ef_construction=64, vector_cosine_ops):
///   - idx_section_embeddings_text_hnsw
///   - idx_section_embeddings_vision_hnsw
///   - idx_section_embeddings_combined_hnsw
///   - idx_section_embeddings_mood_hnsw (Phase 5-4)
///   - idx_section_embeddings_brand_tone_hnsw (Phase 5-4)
/// Performance Target: Vector Search P95 < 100ms
model SectionEmbedding {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionPatternId String @unique @map("section_pattern_id") @db.Uuid

  // テキストベースEmbedding（v1, 768D, multilingual-e5-base）
  // HNSW indexed for semantic search
  textEmbedding Unsupported("vector(768)")? @map("text_embedding")

  // ビジョンベースEmbedding（v2予定, 768D）
  // HNSW indexed for semantic search
  visionEmbedding Unsupported("vector(768)")? @map("vision_embedding")

  // 統合Embedding（v2予定, 768D）
  // HNSW indexed for semantic search
  combinedEmbedding Unsupported("vector(768)")? @map("combined_embedding")

  // ムードEmbedding（Phase 5-4, 768D, multilingual-e5-base）
  // HNSW indexed for semantic search
  // Vision AI検出のmood情報からEmbedding生成
  moodEmbedding Unsupported("vector(768)")? @map("mood_embedding")

  // ブランドトーンEmbedding（Phase 5-4, 768D, multilingual-e5-base）
  // HNSW indexed for semantic search
  // Vision AI検出のbrandTone情報からEmbedding生成
  brandToneEmbedding Unsupported("vector(768)")? @map("brand_tone_embedding")

  // テキスト表現（Embedding生成元）
  textRepresentation String? @map("text_representation") @db.Text

  // 全文検索用tsvectorカラム（GENERATED ALWAYS AS）
  // PostgreSQL側でtext_representationから自動生成、GINインデックス付き
  searchVector Unsupported("tsvector")? @map("search_vector")

  // ムードテキスト表現（Embedding生成元, Phase 5-4）
  // 例: "primary: professional, secondary: minimal, confidence: 0.75"
  moodTextRepresentation String? @map("mood_text_representation") @db.Text

  // ブランドトーンテキスト表現（Embedding生成元, Phase 5-4）
  // 例: "primary: corporate, secondary: innovative, confidence: 0.80"
  brandToneTextRepresentation String? @map("brand_tone_text_representation") @db.Text

  // Embeddingメタデータ
  // 'e5-base-v1', 'llama-vision-v1', 'e5-base-v1-mood', 'e5-base-v1-brandtone'
  modelVersion       String   @map("model_version")
  embeddingTimestamp DateTime @default(now()) @map("embedding_timestamp") @db.Timestamptz

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  sectionPattern SectionPattern @relation(fields: [sectionPatternId], references: [id], onDelete: Cascade)

  @@map("section_embeddings")
}

/// MotionPattern - モーションパターン（scroll_trigger, hover_effect等）
/// category: 'scroll_trigger' | 'hover_effect' | 'page_transition' | 'loading' | etc.
/// triggerType: 'scroll' | 'hover' | 'click' | 'load' | etc.
model MotionPattern {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webPageId String? @map("web_page_id") @db.Uuid // nullableでライブラリ直接登録も可

  // パターン基本情報
  name     String
  // モーションタイプ（css_animation, css_transition, keyframes, library_animation, video_motion）
  type     String?
  // v5.6.0: 新カテゴリ追加 (marquee, video_overlay, parallax, reveal, morphing, background_animation, typing_animation)
  category String // 'scroll_trigger' | 'hover_effect' | 'page_transition' | 'loading_state' | 'micro_interaction' | 'attention_grabber' | 'navigation' | 'feedback' | 'entrance' | 'exit' | 'marquee' | 'video_overlay' | 'parallax' | 'reveal' | 'morphing' | 'background_animation' | 'typing_animation' | 'unknown'

  // トリガー設定
  triggerType   String @map("trigger_type") // 'scroll' | 'hover' | 'click' | 'load'
  triggerConfig Json   @default("{}") @map("trigger_config")

  // アニメーション設定
  animation Json
  /**
   * {
   * "duration": 600,
   * "delay": 0,
   * "easing": { "type": "ease-out" },
   * "iterations": 1,
   * "direction": "normal",
   * "fill_mode": "forwards"
   * }
   */

  // 変化プロパティ
  properties Json @default("[]")
  /**
   * [
   * { "property": "opacity", "from": 0, "to": 1 },
   * { "property": "transform", "from": "translateY(30px)", "to": "translateY(0)" }
   * ]
   */

  // 実装コード
  implementation Json
  /**
   * {
   * "css": "...",
   * "tailwind": "...",
   * "framer_motion": "...",
   * "gsap": "..."
   * }
   */

  // アクセシビリティ
  accessibility Json @default("{}")
  /**
   * {
   * "respects_reduced_motion": true,
   * "alternative_for_reduced": "...",
   * "focus_visible_fallback": "..."
   * }
   */

  // パフォーマンス情報
  performance Json @default("{}")
  /**
   * {
   * "uses_transform": true,
   * "uses_opacity": true,
   * "triggers_layout": false,
   * "triggers_paint": false,
   * "estimated_fps": 60
   * }
   */

  // ソース情報
  sourceUrl  String? @map("source_url") @db.Text
  usageScope String  @default("inspiration_only") @map("usage_scope")

  // メタデータ
  tags     String[] @default([])
  metadata Json     @default("{}")

  // Phase3: 視覚的カテゴリ分類（フレーム差分解析から算出）
  visualCategory   String? @map("visual_category") // 'fade' | 'slide' | 'scale' | 'rotate' | 'parallax' | 'reveal' | 'morph' | 'complex'
  visualConfidence Float?  @map("visual_confidence") // 分類信頼度 (0.0-1.0)
  visualMetrics    Json?   @map("visual_metrics")
  /**
   * {
   * "dominant_direction": "horizontal" | "vertical" | "diagonal" | "radial",
   * "movement_intensity": 0.0-1.0,
   * "change_rate": number,
   * "affected_area_ratio": 0.0-1.0,
   * "frame_diff_stats": {
   * "avg_diff_percentage": number,
   * "max_diff_percentage": number,
   * "motion_consistency": number
   * }
   * }
   */

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage   WebPage?         @relation(fields: [webPageId], references: [id], onDelete: SetNull)
  embedding MotionEmbedding?

  @@index([webPageId])
  @@index([category])
  @@index([type])
  @@index([triggerType])
  @@index([visualCategory])
  @@map("motion_patterns")
}

/// MotionEmbedding - モーションパターンのベクトル埋め込み
/// HNSW Index: idx_motion_embeddings_hnsw (m=16, ef_construction=64, vector_cosine_ops)
/// Performance Target: Vector Search P95 < 100ms
model MotionEmbedding {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  motionPatternId String @unique @map("motion_pattern_id") @db.Uuid

  // テキストベースEmbedding (768D, multilingual-e5-base)
  // HNSW indexed for semantic search
  embedding Unsupported("vector(768)")? @map("embedding")

  // ビジョンベースEmbedding (768D, multilingual-e5-base)
  // HNSW indexed for semantic search
  // Vision AI検出のモーション視覚特徴からEmbedding生成
  visionEmbedding Unsupported("vector(768)")? @map("vision_embedding")

  // テキスト表現（Embedding生成元）
  textRepresentation String? @map("text_representation") @db.Text

  // 全文検索用tsvectorカラム（GENERATED ALWAYS AS）
  // PostgreSQL側でtext_representationから自動生成、GINインデックス付き
  searchVector Unsupported("tsvector")? @map("search_vector")

  // ビジョンテキスト表現（Embedding生成元）
  // 例: "visual_category: pulse, intensity: medium, regions: center"
  visionTextRepresentation String? @map("vision_text_representation") @db.Text

  // メタデータ
  modelVersion       String   @map("model_version")
  embeddingTimestamp DateTime @default(now()) @map("embedding_timestamp") @db.Timestamptz

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  motionPattern MotionPattern @relation(fields: [motionPatternId], references: [id], onDelete: Cascade)

  @@map("motion_embeddings")
}

// ============================================================================
// JS Animation Pattern Models
// JSライブラリ（GSAP, Framer Motion, anime.js, Three.js, Lottie）のアニメーション検出結果
// Web Animations API + CDP からのデータを保存
// ============================================================================

/// JSアニメーションライブラリの種別
enum JSAnimationLibrary {
  gsap
  framer_motion
  anime_js
  three_js
  lottie
  web_animations_api
  unknown
}

/// JSアニメーションの種別
enum JSAnimationType {
  tween // 単純なトゥイーンアニメーション
  timeline // タイムラインベースの複合アニメーション
  spring // バネ物理ベースのアニメーション
  physics // 物理シミュレーション（重力、摩擦等）
  keyframe // キーフレームアニメーション
  morphing // 形状変形アニメーション
  path // パスに沿ったアニメーション
  scroll_driven // スクロール連動アニメーション
  gesture // ジェスチャー連動アニメーション
}

/// JSAnimationPattern - JSライブラリによるアニメーションパターン
/// 既存MotionPattern（CSS静的解析）とは独立したテーブルとして設計
/// GSAP, Framer Motion, anime.js, Three.js, Lottie の検出結果を保存
model JSAnimationPattern {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webPageId String? @map("web_page_id") @db.Uuid

  // ライブラリ情報
  libraryType    JSAnimationLibrary @map("library_type")
  libraryVersion String?            @map("library_version") @db.VarChar(50)

  // アニメーション基本情報
  name          String          @db.VarChar(200)
  animationType JSAnimationType @map("animation_type")
  description   String?         @db.Text

  // ターゲット要素
  targetSelector String?  @map("target_selector") @db.VarChar(500) // CSSセレクタ
  targetCount    Int?     @map("target_count") // 対象要素数
  targetTagNames String[] @default([]) @map("target_tag_names") // div, span, svg等

  // タイミング情報
  durationMs Int?    @map("duration_ms") // アニメーション時間（ミリ秒）
  delayMs    Int?    @map("delay_ms") // 開始遅延（ミリ秒）
  easing     String? @db.VarChar(100) // ease, linear, cubic-bezier(), spring()等
  iterations Int? // 繰り返し回数（-1 = infinite）
  direction  String? @db.VarChar(20) // normal, reverse, alternate, alternate-reverse
  fillMode   String? @map("fill_mode") @db.VarChar(20) // none, forwards, backwards, both

  // キーフレーム情報（Web Animations API から取得）
  // 例: [{ offset: 0, transform: "translateX(0)" }, { offset: 1, transform: "translateX(100px)" }]
  keyframes Json? @default("[]")

  // プロパティ変化情報
  // 例: [{ property: "opacity", from: 0, to: 1 }, { property: "transform", type: "translateX", from: "0px", to: "100px" }]
  properties Json @default("[]")

  // トリガー情報
  triggerType   String? @map("trigger_type") @db.VarChar(50) // scroll, hover, click, load, intersection, gesture
  triggerConfig Json?   @default("{}") @map("trigger_config") // IntersectionObserver設定等

  // CDP（Chrome DevTools Protocol）固有データ
  cdpAnimationId String? @map("cdp_animation_id") @db.VarChar(100) // Chrome Animation ID
  cdpSourceType  String? @map("cdp_source_type") @db.VarChar(50) // CSSAnimation, CSSTransition, WebAnimation
  cdpPlayState   String? @map("cdp_play_state") @db.VarChar(20) // idle, running, paused, finished
  cdpCurrentTime Float?  @map("cdp_current_time") // 現在時刻（秒）
  cdpStartTime   Float?  @map("cdp_start_time") // 開始時刻（秒）
  cdpRawData     Json?   @map("cdp_raw_data") // CDP Animation.animationCreatedイベントの生データ

  // ライブラリ固有データ
  // GSAP: { timeline: { ... }, stagger: 0.1, repeat: 2 }
  // Framer Motion: { variants: { ... }, transition: { ... } }
  // Lottie: { bodymovinVersion: "5.x", totalFrames: 60, frameRate: 30 }
  librarySpecificData Json? @default("{}") @map("library_specific_data")

  // パフォーマンス情報
  performance Json @default("{}")
  /**
   * {
   * "usesTransform": true,
   * "usesOpacity": true,
   * "triggersLayout": false,
   * "triggersPaint": false,
   * "estimatedFps": 60,
   * "gpuAccelerated": true,
   * "willChange": ["transform", "opacity"]
   * }
   */

  // アクセシビリティ
  accessibility Json @default("{}")
  /**
   * {
   * "respectsReducedMotion": true,
   * "reducedMotionAlternative": "fade-only",
   * "prefersReducedMotionQuery": true
   * }
   */

  // ソース情報
  sourceUrl  String? @map("source_url") @db.Text
  usageScope String  @default("inspiration_only") @map("usage_scope")

  // メタデータ
  tags       String[] @default([])
  metadata   Json     @default("{}")
  confidence Float? // 検出信頼度（0-1）

  // タイムスタンプ
  detectedAt DateTime @default(now()) @map("detected_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // リレーション
  webPage   WebPage?              @relation(fields: [webPageId], references: [id], onDelete: SetNull)
  embedding JSAnimationEmbedding?

  @@index([webPageId])
  @@index([libraryType])
  @@index([animationType])
  @@index([triggerType])
  @@index([libraryType, animationType])
  @@index([detectedAt(sort: Desc)])
  @@map("js_animation_patterns")
}

